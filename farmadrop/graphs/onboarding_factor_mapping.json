{
  "meta": {
    "title": "Farmer Onboarding → Drop Score Factor Mapping",
    "purpose": "Defines how LocalHarvest farmer-onboarding answers map into the Drop Score regenerative factor tree. Onboarding text and structured selections are EVIDENCE; the score is derived from mapped claims and their evidence strength — never from the raw text itself.",
    "source_repo": "LocalHarvest",
    "score_repo": "kg_farmadrop",
    "onboarding_surface": "test.farmerdrop.com/apply/farmer",
    "factor_graph": "graphs/drop_score_graph.json",
    "node_id_note": "Every key under `factor_evidence_terms` is a REAL tier-2 factor id from drop_score_graph.json (19 factors across 5 domains). No new node ids are introduced here.",
    "no_weights_note": "Consistent with the Drop Score graph: there are no weights and no single opaque number. This file maps onboarding evidence onto named, evidenceable indicators."
  },

  "onboarding_fields": {
    "farm_description": {
      "form_field": "description",
      "purpose": "public identity + summary",
      "feeds_scoring": false
    },
    "practices_text": {
      "form_field": "farmingPractices",
      "purpose": "regenerative-practice evidence (free text, keyword + semantic mapped)",
      "feeds_scoring": true
    },
    "product_categories": {
      "form_field": "specialty",
      "purpose": "marketplace browsing labels; only indirect scoring via mapped practices",
      "feeds_scoring": "indirect"
    },
    "product_attributes": {
      "form_field": "farmingPractices (appended sentence)",
      "purpose": "packaging / perishability / processing / sourcing evidence",
      "feeds_scoring": true
    },
    "certifications": {
      "form_field": "certifications",
      "purpose": "evidence-strength upgrade (third_party) where present",
      "feeds_scoring": true
    }
  },

