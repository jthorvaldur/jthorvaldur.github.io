  "template_weighting": {
    "note": "TEMPLATE weights + a sigmoid scale that turn matched evidence into a formal Drop Score in [0,1]. The knowledge graph itself is weightless; this is an overlay for scoring, tunable and non-final. The running implementation is LocalHarvest shared/drop-score.ts — keep the two in sync. Iterate on the numbers here first.",
    "intake_model": "One checkbox per subcategory (factor) => 0 or 1. Non-applicable domains are excluded from the denominator, never scored zero.",
    "domain_weights": {
      "d_soil": 0.25,
      "d_diversity": 0.2,
      "d_practices": 0.25,
      "d_animal": 0.15,
      "d_community": 0.15
    },
    "factor_weighting": "Equal within each domain by default (weight 1 each), normalized by domain factor count.",
    "coverage_formula": "coverage = sum over applicable domains [ domain_weight * (matched_factor_weight / total_factor_weight) ] / sum(applicable domain_weight). Range [0,1].",
    "sigmoid": {
      "form": "normalized logistic: score(c) = (L(k(c-m)) - L(k(0-m))) / (L(k(1-m)) - L(k(0-m))), L(x)=1/(1+e^-x)",
      "steepness_k": 6,
      "midpoint_m": 0.5,
      "endpoints": "score(0)=0, score(0.5)=0.5, score(1)=1; S-shaped between (below midpoint compresses, above expands)"
    },
    "worked_example_score": {
      "farm_id": "example_papaya_habanero_mallorca",
      "selected_factors": ["soil_carbon", "soil_cover", "tillage", "market_diversity", "nutrient_mgmt", "water_stewardship"],
      "coverage": 0.29,
      "score": 0.1917
    }
  },

  "factor_status": {
    "claimed": "Farmer states a relevant practice.",
    "verified": "Claim supported by certification, uploaded evidence, inspection, lab test, photo record, or trusted-partner confirmation.",
    "missing": "Relevant but not described.",
    "not_applicable": "Not relevant to this farm type or product model. NEVER scored as zero — excluded / neutralized instead."
  },

  "evidence_strength": {
    "none": "No evidence supplied.",
    "claim": "Farmer states the practice.",
    "record": "Farmer has logs, dates, photos, input receipts, or process notes.",
    "third_party": "Certification, inspection, lab report, or outside verification."
  },

  "data_contract": {
    "boundary": "LocalHarvest owns onboarding UX + profile content and MUST NOT hard-code scoring weights. It sends structured claims + product metadata; kg_farmadrop owns taxonomy, node definitions, mapping, confidence, not-applicable handling, and explanations.",
    "request_localharvest_to_kg_farmadrop": {
      "farm_id": "farm_123",
      "source": "LocalHarvest.onboarding",
      "farm_description": "string",
      "practices_text": "string",
      "product_categories_normalized": ["fresh_fruit", "tropical_fruit", "peppers", "hot_sauce", "preserves_pantry"],
      "product_attributes": ["shelf_stable", "glass_packaging", "value_added", "locally_sourced"],
      "not_applicable": [{ "node": "d_animal", "reason": "No livestock products sold." }],
      "farmer_claims": [{ "node": "soil_cover", "claim": "mulch and crop residues", "evidence_strength": "claim" }]
    },
    "response_kg_farmadrop_to_localharvest": {
      "drop_score": null,
      "score_status": "draft_insufficient_evidence",
      "mapped_nodes": [],
      "missing_evidence_prompts": [],
      "not_applicable_nodes": [],
      "public_explanation": ""
    }
  },

