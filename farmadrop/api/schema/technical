{"diffs":[{"object_name":"ledger_entries","current_localharvest":"Signed party-oriented rows with order/packing/shipment references, adjusts_entry_id, settlement_date, and created_at.","proposed_change":"Add nullable ledger_event_id, line_number, account_code, effective_at, and immutable posted_at; backfill before NOT NULL enforcement.","reason":"Group atomic legs, make double-entry machine-checkable, and preserve economic versus knowledge time.","recommendation":"extend","decision_state":"agreed-core"},{"object_name":"ledger_events","current_localharvest":"No event header; idempotency is split across payment references and payout/outbox keys.","proposed_change":"New idempotent event header with event_key, event_type, status, source identity, correction link, effective_at, and posted_at.","reason":"One durable identity for every balanced posting batch and correction.","recommendation":"add","decision_state":"agreed-core"},{"object_name":"stripe_transactions","current_localharvest":"Durable outbound intent/outbox already exists.","proposed_change":"Keep it; link successful/failed intent rows to ledger_events and observed Stripe objects.","reason":"Intent and observed cash movement are different facts.","recommendation":"retain","decision_state":"agreed-core"},{"object_name":"stripe_balance_transactions","current_localharvest":"Admin reads Stripe activity, but no normalized local fact table is authoritative for observed fees/cash.","proposed_change":"Add an idempotent mirror keyed by Stripe balance transaction id, with gross, fee, net, available_on, source object, and raw snapshot.","reason":"Reconcile internal cash and fee entries to actual Stripe facts rather than modeled percentages.","recommendation":"add","decision_state":"agreed-core"},{"object_name":"holding / stripe / stripe_fee parties","current_localharvest":"Implemented by migrations 0025\u20130027 and escrow-ledger helpers.","proposed_change":"Keep these primitives and map them to account_code/book views; do not create competing cash ledgers.","reason":"The missing clearing capability is already present in current code.","recommendation":"retain","decision_state":"agreed-core"},{"object_name":"responsibility_decisions","current_localharvest":"Delivery issues and pickup resolutions record outcomes, but no versioned per-source participant allocation fact.","proposed_change":"Open option: versioned decision rows could separate liability adjudication from refund execution.","reason":"A refund amount and a participant recovery decision must remain separate.","recommendation":"open","decision_state":"open-decision"},{"object_name":"remedy_lines","current_localharvest":"pickup_resolutions stores order-level refund/credit amounts; ledger rows store economic consequences.","proposed_change":"Open option: immutable per-source remedy legs could preserve merchandise, tax, fixed-fee, method, and supersession provenance.","reason":"Exact partial refunds and tax reversals need line-level source identity.","recommendation":"open","decision_state":"open-decision"},{"object_name":"six ledger tables","current_localharvest":"One ledger_entries table plus party types and clearing helpers.","proposed_change":"Open physical-design choice: one dimensioned posting table, six physical tables, or a hybrid with materialized views.","reason":"The six-book grouping remains a hypothesis and should be re-taggable without rewriting postings.","recommendation":"open","decision_state":"open-decision"}],"postgres_ddl":"-- Agreed core candidate v0.2 for Volk review; not approved for production.\nCREATE EXTENSION IF NOT EXISTS pgcrypto;\n\nCREATE TABLE ledger_events (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  event_key text NOT NULL UNIQUE,\n  event_type text NOT NULL,\n  status text NOT NULL CHECK (status IN ('pending','posted','reversed','failed')),\n  order_id integer REFERENCES orders(id),\n  source_type text NOT NULL,\n  source_id text NOT NULL,\n  effective_at timestamptz NOT NULL,\n  posted_at timestamptz NOT NULL DEFAULT now(),\n  corrects_event_id uuid REFERENCES ledger_events(id),\n  metadata jsonb NOT NULL DEFAULT '{}'::jsonb\n);\n\nALTER TABLE ledger_entries\n  ADD COLUMN ledger_event_id uuid REFERENCES ledger_events(id),\n  ADD COLUMN line_number integer,\n  ADD COLUMN account_code text,\n  ADD COLUMN effective_at timestamptz,\n  ADD COLUMN posted_at timestamptz NOT NULL DEFAULT now();\n\nCREATE UNIQUE INDEX uq_ledger_event_line\n  ON ledger_entries (ledger_event_id, line_number)\n  WHERE ledger_event_id IS NOT NULL;\nCREATE INDEX idx_ledger_effective_at ON ledger_entries (effective_at);\nCREATE INDEX idx_ledger_posted_at ON ledger_entries (posted_at);\n\nCREATE TABLE stripe_balance_transactions (\n  stripe_id text PRIMARY KEY,\n  source_object_id text,\n  source_type text NOT NULL,\n  currency text NOT NULL,\n  gross_minor bigint NOT NULL,\n  fee_minor bigint NOT NULL,\n  net_minor bigint NOT NULL,\n  status text NOT NULL,\n  available_on timestamptz,\n  observed_at timestamptz NOT NULL DEFAULT now(),\n  raw_snapshot jsonb NOT NULL,\n  CHECK (gross_minor - fee_minor = net_minor)\n);\n","drizzle_diff":"// Candidate additions to shared/schema.ts (shape only).\nexport const ledgerEvents = pgTable('ledger_events', {\n  id: uuid('id').defaultRandom().primaryKey(),\n  eventKey: text('event_key').notNull().unique(),\n  eventType: text('event_type').notNull(),\n  status: text('status').notNull(),\n  orderId: integer('order_id').references(() => orders.id),\n  sourceType: text('source_type').notNull(),\n  sourceId: text('source_id').notNull(),\n  effectiveAt: timestamp('effective_at', { withTimezone: true }).notNull(),\n  postedAt: timestamp('posted_at', { withTimezone: true }).defaultNow().notNull(),\n  correctsEventId: uuid('corrects_event_id'),\n  metadata: jsonb('metadata').notNull().default({}),\n});\n\n// Extend ledgerEntries; backfill before making the first four fields required.\nledgerEventId: uuid('ledger_event_id').references(() => ledgerEvents.id),\nlineNumber: integer('line_number'),\naccountCode: text('account_code'),\neffectiveAt: timestamp('effective_at', { withTimezone: true }),\npostedAt: timestamp('posted_at', { withTimezone: true }).defaultNow().notNull(),\n","open_decision_ddl":"-- OPTIONAL SHAPES ONLY: no decision has been made to add these tables.\nCREATE TABLE responsibility_decisions (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  order_item_id integer NOT NULL REFERENCES order_items(id),\n  actor_type text NOT NULL,\n  actor_id text NOT NULL,\n  quantity numeric(14,3) NOT NULL CHECK (quantity >= 0),\n  reason text NOT NULL,\n  status text NOT NULL,\n  decision_version integer NOT NULL CHECK (decision_version > 0),\n  supersedes_id uuid REFERENCES responsibility_decisions(id),\n  effective_at timestamptz NOT NULL,\n  posted_at timestamptz NOT NULL DEFAULT now(),\n  evidence jsonb NOT NULL DEFAULT '[]'::jsonb,\n  UNIQUE (order_item_id, actor_type, actor_id, decision_version)\n);\n\nCREATE TABLE remedy_lines (\n  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),\n  resolution_id integer NOT NULL REFERENCES pickup_resolutions(id),\n  order_item_id integer NOT NULL REFERENCES order_items(id),\n  quantity numeric(14,3) NOT NULL CHECK (quantity > 0),\n  merchandise_minor bigint NOT NULL CHECK (merchandise_minor >= 0),\n  tax_minor bigint NOT NULL CHECK (tax_minor >= 0),\n  fixed_fee_minor bigint NOT NULL CHECK (fixed_fee_minor >= 0),\n  method text NOT NULL CHECK (method IN ('original_tender','credit','replacement')),\n  tax_components jsonb NOT NULL DEFAULT '[]'::jsonb,\n  effective_at timestamptz NOT NULL,\n  posted_at timestamptz NOT NULL DEFAULT now()\n);\n","migration_ready":false}